+static std::string
+xr_debug_safe_env_suffix(const char *name)
+{
+	const char *v = std::getenv(name);
+	if (v == nullptr || v[0] == '\0') {
+		return "";
+	}
+
+	std::string out;
+	for (const char *p = v; *p != '\0'; ++p) {
+		const char c = *p;
+		if ((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9') || c == '_' ||
+		    c == '-') {
+			out.push_back(c);
+		} else {
+			out.push_back('_');
+		}
+	}
+	return out;
