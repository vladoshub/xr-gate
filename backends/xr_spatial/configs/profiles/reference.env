# Generic reference profile for xr_spatial_backend.
# Copy this file when adding a new camera/device profile. Do not edit scripts for
# device-specific stream names, calibration paths, frame IDs, or depth tuning.

SPATIAL_MAPPER_PROFILE_NAME="${SPATIAL_MAPPER_PROFILE_NAME:-reference}"
CALIB_PROFILE_NAME="${CALIB_PROFILE_NAME:-unknown}"

# Required for real runs. Keep empty here so the reference profile is device-neutral.
CALIB_JSON="${CALIB_JSON:-}"

# Capture input streams.
CAPTURE_REGISTRY="${CAPTURE_REGISTRY:-/tmp/capture_service_streams.json}"
CAMERA0_STREAM="${CAMERA0_STREAM:-camera0}"
CAMERA1_STREAM="${CAMERA1_STREAM:-camera1}"
IMU_STREAM="${IMU_STREAM:-imu0}"

# Optional read-only tracking pose input. Use SPATIAL_POSE_INPUT=none for camera-frame
# stereo-only live depth without a tracking backend.
SPATIAL_POSE_INPUT="${SPATIAL_POSE_INPUT:-${POSE_INPUT:-shm}}"
POSE_REGISTRY="${POSE_REGISTRY:-/tmp/tracking_streams.json}"
POSE_STREAM="${POSE_STREAM:-hmd_pose}"
POSE_FRAME_ID="${POSE_FRAME_ID:-tracking_pose}"
MAX_POSE_AGE_MS="${MAX_POSE_AGE_MS:-120}"
POSE_REATTACH_ON_STALE_MS="${POSE_REATTACH_ON_STALE_MS:-500}"
STEREO_POSE_SYNC_SCAN_BACK="${STEREO_POSE_SYNC_SCAN_BACK:-16}"
DROP_STALE_POSE="${DROP_STALE_POSE:-1}"

# Frame naming / map convention.
DEPTH_FRAME_ID="${DEPTH_FRAME_ID:-cam0_rect}"
if [[ "$SPATIAL_POSE_INPUT" == "none" ]]; then
  MAP_FRAME_ID="${MAP_FRAME_ID:-$DEPTH_FRAME_ID}"
  SPATIAL_MAP_FRAME="${SPATIAL_MAP_FRAME:-camera}" # tracking|camera
else
  MAP_FRAME_ID="${MAP_FRAME_ID:-tracking_world}"
  SPATIAL_MAP_FRAME="${SPATIAL_MAP_FRAME:-tracking}" # tracking|camera
fi

# Stereo rectification/depth tuning.
FISHEYE_BALANCE="${FISHEYE_BALANCE:-0.0}"
ZERO_DISPARITY="${ZERO_DISPARITY:-1}"
DEPTH_RATE_HZ="${DEPTH_RATE_HZ:-10}"
NUM_DISPARITIES="${NUM_DISPARITIES:-128}"
BLOCK_SIZE="${BLOCK_SIZE:-7}"
UNIQUENESS_RATIO="${UNIQUENESS_RATIO:-10}"
SPECKLE_WINDOW_SIZE="${SPECKLE_WINDOW_SIZE:-100}"
SPECKLE_RANGE="${SPECKLE_RANGE:-2}"
POINT_DECIMATION="${POINT_DECIMATION:-8}"
MIN_DEPTH_M="${MIN_DEPTH_M:-0.25}"
MAX_DEPTH_M="${MAX_DEPTH_M:-2.5}"
MAX_ABS_CAMERA_COORDINATE_M="${MAX_ABS_CAMERA_COORDINATE_M:-20.0}"
# Normalized central ROI for point extraction. Use this to avoid noisy borders and off-target clutter.
DEPTH_ROI_X_MIN="${DEPTH_ROI_X_MIN:-0.0}"
DEPTH_ROI_X_MAX="${DEPTH_ROI_X_MAX:-1.0}"
DEPTH_ROI_Y_MIN="${DEPTH_ROI_Y_MIN:-0.0}"
DEPTH_ROI_Y_MAX="${DEPTH_ROI_Y_MAX:-1.0}"
MAX_ACCUMULATED_POINTS="${MAX_ACCUMULATED_POINTS:-1000000}"
MAX_ABS_MAP_COORDINATE_M="${MAX_ABS_MAP_COORDINATE_M:-100.0}"
TRACKING_ORIGIN="${TRACKING_ORIGIN:-first_pose}"

# Mapper/filter settings. Copy and tune for another camera profile.
MAPPER_BACKEND="${MAPPER_BACKEND:-live_depth_grid}" # live_depth_grid|pointcloud_fallback
POINT_VOXEL_SIZE_M="${POINT_VOXEL_SIZE_M:-0.01}"
MAX_POINTS_PER_FRAME="${MAX_POINTS_PER_FRAME:-60000}"

# Frame quality gate before map/TSDF integration. Keep in profile so camera/device changes do not require code edits.
QUALITY_GATE_ENABLED="${QUALITY_GATE_ENABLED:-0}"
QUALITY_MIN_RAW_POINTS="${QUALITY_MIN_RAW_POINTS:-1000}"
QUALITY_MIN_FILTERED_POINTS="${QUALITY_MIN_FILTERED_POINTS:-500}"
QUALITY_FAR_DEPTH_M="${QUALITY_FAR_DEPTH_M:-0}"
QUALITY_MAX_FAR_POINT_FRACTION="${QUALITY_MAX_FAR_POINT_FRACTION:-1.0}"
QUALITY_MAX_POSE_DELTA_M="${QUALITY_MAX_POSE_DELTA_M:-0}"
QUALITY_MAX_POSE_DELTA_DEG="${QUALITY_MAX_POSE_DELTA_DEG:-0}"
QUALITY_WRITE_CSV="${QUALITY_WRITE_CSV:-1}"
QUALITY_CSV_NAME="${QUALITY_CSV_NAME:-quality_gate.csv}"


# Debug output.
SAVE_DEBUG_CLOUDS="${SAVE_DEBUG_CLOUDS:-1}"
SAVE_DEBUG_FRAMES="${SAVE_DEBUG_FRAMES:-1}"

# Runtime spatial summary output.
PUBLISH_RUNTIME_SPATIAL_SHM="${PUBLISH_RUNTIME_SPATIAL_SHM:-1}"
RUNTIME_REGISTRY="${RUNTIME_REGISTRY:-/tmp/runtime_tracking_streams.json}"
SPATIAL_STREAM="${SPATIAL_STREAM:-runtime_spatial_summary}"
SPATIAL_SHM_NAME="${SPATIAL_SHM_NAME:-runtime_spatial_summary}"

# Low-poly/voxel proxy mesh for SteamVR/remote overlay.
SPATIAL_PROXY_MESH_ENABLED="${SPATIAL_PROXY_MESH_ENABLED:-1}"
PUBLISH_SPATIAL_PROXY_MESH_SHM="${PUBLISH_SPATIAL_PROXY_MESH_SHM:-1}"
SPATIAL_PROXY_MESH_STREAM="${SPATIAL_PROXY_MESH_STREAM:-spatial_proxy_mesh}"
SPATIAL_PROXY_MESH_SHM_NAME="${SPATIAL_PROXY_MESH_SHM_NAME:-spatial_proxy_mesh}"
SPATIAL_PROXY_MESH_RATE_HZ="${SPATIAL_PROXY_MESH_RATE_HZ:-2}"
SPATIAL_PROXY_MESH_VOXEL_SIZE_M="${SPATIAL_PROXY_MESH_VOXEL_SIZE_M:-0.08}"
SPATIAL_PROXY_MESH_MAX_DISTANCE_M="${SPATIAL_PROXY_MESH_MAX_DISTANCE_M:-2.5}"
SPATIAL_PROXY_MESH_MAX_VERTICES="${SPATIAL_PROXY_MESH_MAX_VERTICES:-8192}"
SPATIAL_PROXY_MESH_MAX_TRIANGLES="${SPATIAL_PROXY_MESH_MAX_TRIANGLES:-12000}"
SPATIAL_PROXY_MESH_MIN_POINTS_PER_VOXEL="${SPATIAL_PROXY_MESH_MIN_POINTS_PER_VOXEL:-1}"
SPATIAL_LIVE_GRID_TRIANGLES_ENABLED="${SPATIAL_LIVE_GRID_TRIANGLES_ENABLED:-1}"
SPATIAL_LIVE_GRID_MAX_EDGE_M="${SPATIAL_LIVE_GRID_MAX_EDGE_M:-0.10}"
SPATIAL_LIVE_GRID_MAX_DEPTH_JUMP_M="${SPATIAL_LIVE_GRID_MAX_DEPTH_JUMP_M:-0.10}"

# Scan mode.
SCAN_DURATION_SEC="${SCAN_DURATION_SEC:-30}"
SCAN_OUTPUT_ROOT="${SCAN_OUTPUT_ROOT:-$HOME/xr_spatial_scans}"
SCAN_OUTPUT_DIR="${SCAN_OUTPUT_DIR:-$SCAN_OUTPUT_ROOT/scan_$(date +%Y%m%d_%H%M%S)}"
RESET_MAP_ON_SCAN_START="${RESET_MAP_ON_SCAN_START:-1}"
EXIT_AFTER_SCAN="${EXIT_AFTER_SCAN:-1}"
SAVE_POINTCLOUD_PLY="${SAVE_POINTCLOUD_PLY:-1}"
SAVE_VOXEL_POINTCLOUD_PLY="${SAVE_VOXEL_POINTCLOUD_PLY:-1}"
SCAN_VOXEL_SIZE_M="${SCAN_VOXEL_SIZE_M:-0.02}"
SCAN_MIN_OBSERVATIONS="${SCAN_MIN_OBSERVATIONS:-2}"
SCAN_MAX_VOXEL_POINTS="${SCAN_MAX_VOXEL_POINTS:-200000}"
SAVE_TRAJECTORY_CSV="${SAVE_TRAJECTORY_CSV:-1}"
SAVE_METADATA_JSON="${SAVE_METADATA_JSON:-1}"
PRINT_EVERY="${PRINT_EVERY:-30}"

# Pose health / pose-source reinitialization diagnostics. Keep thresholds profile-owned.
QUALITY_REINIT_DELTA_M="${QUALITY_REINIT_DELTA_M:-1.0}"
QUALITY_REINIT_DELTA_DEG="${QUALITY_REINIT_DELTA_DEG:-45.0}"
QUALITY_WRITE_POSE_HEALTH_CSV="${QUALITY_WRITE_POSE_HEALTH_CSV:-1}"
QUALITY_POSE_HEALTH_CSV_NAME="${QUALITY_POSE_HEALTH_CSV_NAME:-pose_health.csv}"

# Startup-order and backend-restart safety for pose SHM.
POSE_WAIT_TIMEOUT_SEC="${POSE_WAIT_TIMEOUT_SEC:-0}"
POSE_RETRY_INTERVAL_MS="${POSE_RETRY_INTERVAL_MS:-500}"
POSE_REATTACH_ON_STALE_MS="${POSE_REATTACH_ON_STALE_MS:-500}"
