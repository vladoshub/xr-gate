# Legacy compatibility wrapper.
# Prefer:
#   XR_SPATIAL_PROFILE=xreal_air2ultra_unified_480 \
#     backends/xr_spatial/scripts/linux/start_xr_spatial_scan.sh

_THIS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$_THIS_DIR/profiles/xreal_air2ultra_unified_480.env"

# Startup-order and backend-restart safety for pose SHM.
POSE_WAIT_TIMEOUT_SEC="${POSE_WAIT_TIMEOUT_SEC:-0}"
POSE_RETRY_INTERVAL_MS="${POSE_RETRY_INTERVAL_MS:-500}"
POSE_REATTACH_ON_STALE_MS="${POSE_REATTACH_ON_STALE_MS:-500}"
