#!/usr/bin/env bash
# XREAL Ultra shared environment for xr_client and launcher scripts.
#
# This file is intentionally shell-compatible. xr_client sources it before it
# expands service commands, and every device-local wrapper sources it before it
# starts a service. Move this folder to another machine and override XR_BIN_ROOT
# / XR_DEVICE_HOME if the binaries and device files are installed elsewhere.

_XR_DEVICE_ENV_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# -----------------------------------------------------------------------------
# Global roots
# -----------------------------------------------------------------------------
export XR_TARGET_DEVICE="${XR_TARGET_DEVICE:-xreal_ultra}"
export XR_DEVICE_TARGET="${XR_DEVICE_TARGET:-$XR_TARGET_DEVICE}"
export XR_DEVICE_HOME="${XR_DEVICE_HOME:-$_XR_DEVICE_ENV_DIR}"
export XR_PACKAGE_ROOT="${XR_PACKAGE_ROOT:-$(cd "$XR_DEVICE_HOME/../.." && pwd)}"
export XR_ROOT_PROJECT="${XR_ROOT_PROJECT:-$XR_PACKAGE_ROOT}"
export ROOT_PROJECT="${ROOT_PROJECT:-$XR_ROOT_PROJECT}"
export XR_OUT_ROOT="${XR_OUT_ROOT:-$XR_ROOT_PROJECT/out/xreal_ultra}"
export XR_BIN_ROOT="${XR_BIN_ROOT:-$XR_ROOT_PROJECT/bin}"
if [[ -d "$XR_BIN_ROOT/python" ]]; then
  export XR_PYTHON_ROOT="${XR_PYTHON_ROOT:-$XR_BIN_ROOT/python}"
else
  export XR_PYTHON_ROOT="${XR_PYTHON_ROOT:-$XR_ROOT_PROJECT}"
fi
export XR_CLIENT_DIR="${XR_CLIENT_DIR:-$XR_PYTHON_ROOT/xr_client}"
export XR_TOOLS_DIR="${XR_TOOLS_DIR:-$XR_PYTHON_ROOT/tools}"
export PYTHONPATH="$XR_PYTHON_ROOT:$XR_CLIENT_DIR:$XR_TOOLS_DIR:${PYTHONPATH:-}"
export XR_DEVICE_SCRIPTS_ROOT="${XR_DEVICE_SCRIPTS_ROOT:-$XR_DEVICE_HOME/linux/scripts}"
export XR_DEVICE_CONFIGS_ROOT="${XR_DEVICE_CONFIGS_ROOT:-$XR_DEVICE_HOME/configs}"
export XR_CALIB_DIR="${XR_CALIB_DIR:-$XR_DEVICE_CONFIGS_ROOT/calibration_dataset}"

# Shared runtime registries
export CAPTURE_REGISTRY="${CAPTURE_REGISTRY:-/tmp/capture_service_streams.json}"
export TRACKING_REGISTRY="${TRACKING_REGISTRY:-/tmp/tracking_streams.json}"
export RUNTIME_REGISTRY="${RUNTIME_REGISTRY:-/tmp/runtime_tracking_streams.json}"
export RUNTIME_TRACKING_REGISTRY="${RUNTIME_TRACKING_REGISTRY:-$RUNTIME_REGISTRY}"
export XR_BACKEND_CONTROL_FILE="${XR_BACKEND_CONTROL_FILE:-/tmp/xr_backend_control.json}"

# Device identity / calibration profile
export XR_DEVICE_NAME="${XR_DEVICE_NAME:-xreal_air2ultra}"
export XR_SERIAL="${XR_SERIAL:-ZBBM5DZFMP}"
export CALIB_PROFILE_NAME="${CALIB_PROFILE_NAME:-unified_480_ccw90}"
export FINAL_PROFILE_DIR="${FINAL_PROFILE_DIR:-$XR_CALIB_DIR/final/$XR_DEVICE_NAME/$XR_SERIAL/$CALIB_PROFILE_NAME}"

# -----------------------------------------------------------------------------
# xreal_display_helper
# -----------------------------------------------------------------------------
export XREAL_DISPLAY_HELPER_BIN="${XREAL_DISPLAY_HELPER_BIN:-$XR_BIN_ROOT/xreal_display_helper/xreal_display_helper}"

# -----------------------------------------------------------------------------
# capture_service: native C++ backend
# -----------------------------------------------------------------------------
export CAPTURE_SERVICE_IMPL="${CAPTURE_SERVICE_IMPL:-${XR_CAPTURE_SERVICE_IMPL:-cpp}}"
export CAPTURE_SERVICE_CPP_BIN="${CAPTURE_SERVICE_CPP_BIN:-$XR_BIN_ROOT/capture_service_cpp/capture_service_cpp}"
export CAPTURE_SERVICE_CONFIG_PATH="${CAPTURE_SERVICE_CONFIG_PATH:-$XR_DEVICE_CONFIGS_ROOT/capture_service/xreal_air2ultra_linux_unified_480_shm.yaml}"

# -----------------------------------------------------------------------------
# basalt_vio
# -----------------------------------------------------------------------------
export BASALT_BIN_DIR="${BASALT_BIN_DIR:-$XR_BIN_ROOT/backends/basalt_vio}"
export BASALT_LIB_DIR="${BASALT_LIB_DIR:-$BASALT_BIN_DIR/lib}"

# -----------------------------------------------------------------------------
# imu_3dof_backend
# -----------------------------------------------------------------------------
export IMU_3DOF_BACKEND_BIN="${IMU_3DOF_BACKEND_BIN:-$XR_BIN_ROOT/backends/imu_3dof/imu_3dof_backend}"

# -----------------------------------------------------------------------------
# mercury_hand_tracking
# -----------------------------------------------------------------------------
export MERCURY_HAND_TRACKING_BIN_DIR="${MERCURY_HAND_TRACKING_BIN_DIR:-$XR_BIN_ROOT/backends/mercury_hand_tracking}"
export BACKEND_BIN="${BACKEND_BIN:-$MERCURY_HAND_TRACKING_BIN_DIR/capture_hand_tracking_backend}"
export MERCURY_LIB="${MERCURY_LIB:-$MERCURY_HAND_TRACKING_BIN_DIR/libxr_mercury_runtime.so}"
export MERCURY_MODELS="${MERCURY_MODELS:-$XR_BIN_ROOT/hand-tracking-models/mercury}"
export ORT_ROOT="${ORT_ROOT:-$XR_BIN_ROOT/onnxruntime/onnxruntime-linux-x64-1.18.1}"

# -----------------------------------------------------------------------------
# xr_runtime_adapter
# -----------------------------------------------------------------------------
export XR_RUNTIME_ADAPTER_BIN="${XR_RUNTIME_ADAPTER_BIN:-$XR_BIN_ROOT/runtime_adapters/xr_runtime_adapter/xr_runtime_adapter}"
export TRACKING_TRANSFORM_CONFIG="${TRACKING_TRANSFORM_CONFIG:-$XR_DEVICE_CONFIGS_ROOT/xr_runtime_adapter/xr_21_joint_hand_viewer_verified.json}"

# -----------------------------------------------------------------------------
# override_controller
# -----------------------------------------------------------------------------
export OVERRIDE_CONTROLLER_DIR="${OVERRIDE_CONTROLLER_DIR:-$XR_DEVICE_HOME}"
export OVERRIDE_CONTROLLER_BIN="${OVERRIDE_CONTROLLER_BIN:-$XR_BIN_ROOT/override_controller/override_controller}"
export AUTO_BUILD="${AUTO_BUILD:-0}"

# -----------------------------------------------------------------------------
# xr_video
# -----------------------------------------------------------------------------
export BIN_DIR_XR_VIDEO="${BIN_DIR_XR_VIDEO:-$XR_BIN_ROOT/backends/xr_video}"
export XR_VIDEO_BACKEND_BIN="${XR_VIDEO_BACKEND_BIN:-$BIN_DIR_XR_VIDEO/xr_video_backend}"

# -----------------------------------------------------------------------------
# xr_spatial
# -----------------------------------------------------------------------------
export BIN_DIR_XR_SPATIAL="${BIN_DIR_XR_SPATIAL:-$XR_BIN_ROOT/backends/xr_spatial}"
export XR_SPATIAL_BIN="${XR_SPATIAL_BIN:-$BIN_DIR_XR_SPATIAL/xr_spatial_backend}"
export XR_SPATIAL_CONFIG="${XR_SPATIAL_CONFIG:-$XR_DEVICE_CONFIGS_ROOT/xr_spatial/profiles/xreal_air2ultra_unified_480.env}"
export SPATIAL_PROXY_MESH_RATE_HZ="${SPATIAL_PROXY_MESH_RATE_HZ:-10}"


# -----------------------------------------------------------------------------
# SteamVR / OpenVR driver
# -----------------------------------------------------------------------------
export XR_OPENVR_DEVICE="${XR_OPENVR_DEVICE:-$XR_DEVICE_TARGET}"
export XR_OPENVR_DISPLAY_FREQUENCY_HZ="${XR_OPENVR_DISPLAY_FREQUENCY_HZ:-${XR_DISPLAY_FREQUENCY_HZ:-60}}"
export XR_OPENVR_DISPLAY_MODE="${XR_OPENVR_DISPLAY_MODE:-${XR_STEAMVR_DISPLAY_MODE:-direct}}"
_XR_OPENVR_DISPLAY_MODE_NORMALIZED="${XR_OPENVR_DISPLAY_MODE,,}"
_XR_OPENVR_DISPLAY_MODE_NORMALIZED="${_XR_OPENVR_DISPLAY_MODE_NORMALIZED//-/_}"
case "$_XR_OPENVR_DISPLAY_MODE_NORMALIZED" in
  extended|extended_sbs|sbs|windowed|desktop)
    export XR_OPENVR_DISPLAY_MODE="extended_sbs"
    _XR_OPENVR_MODE_SUFFIX="_extended_sbs"
    ;;
  *)
    export XR_OPENVR_DISPLAY_MODE="direct"
    _XR_OPENVR_MODE_SUFFIX=""
    ;;
esac
export XR_OPENVR_DRIVER_DIR_NAME="${XR_OPENVR_DRIVER_DIR_NAME:-openvr_driver_${XR_OPENVR_DISPLAY_FREQUENCY_HZ}HZ${_XR_OPENVR_MODE_SUFFIX}}"
export OPENVR_DRIVER_ROOT="${OPENVR_DRIVER_ROOT:-$XR_BIN_ROOT/drivers/$XR_OPENVR_DRIVER_DIR_NAME}"
export OPENVR_DRIVER_PACKAGE="${OPENVR_DRIVER_PACKAGE:-$OPENVR_DRIVER_ROOT/xr_tracking}"
export OPENVR_REGISTER_DRIVER_SCRIPT="${OPENVR_REGISTER_DRIVER_SCRIPT:-$OPENVR_DRIVER_ROOT/scripts/register_driver.sh}"
unset _XR_OPENVR_DISPLAY_MODE_NORMALIZED _XR_OPENVR_MODE_SUFFIX

# -----------------------------------------------------------------------------
# Monado driver
# -----------------------------------------------------------------------------
export XR_MONADO_DEVICE="${XR_MONADO_DEVICE:-$XR_DEVICE_TARGET}"
export MONADO_DRIVER_ROOT="${MONADO_DRIVER_ROOT:-$XR_BIN_ROOT/drivers/monado_driver}"
export XR_MONADO_SERVICE_BIN="${XR_MONADO_SERVICE_BIN:-$MONADO_DRIVER_ROOT/monado-service}"
export XR_MONADO_START_SCRIPT="${XR_MONADO_START_SCRIPT:-$MONADO_DRIVER_ROOT/start.sh}"

# XREAL Air 2 Ultra SBS display profile for the generic Monado runtime driver.
# Keep these values in the device environment so another glasses profile can
# override display/FOV/refresh without editing driver C++ code.
export XR_MONADO_RENDER_WIDTH="${XR_MONADO_RENDER_WIDTH:-1920}"
export XR_MONADO_RENDER_HEIGHT="${XR_MONADO_RENDER_HEIGHT:-1080}"
export XR_MONADO_WINDOW_WIDTH="${XR_MONADO_WINDOW_WIDTH:-3840}"
export XR_MONADO_WINDOW_HEIGHT="${XR_MONADO_WINDOW_HEIGHT:-1080}"
export XR_MONADO_DISPLAY_WIDTH_M="${XR_MONADO_DISPLAY_WIDTH_M:-0.120}"
export XR_MONADO_DISPLAY_HEIGHT_M="${XR_MONADO_DISPLAY_HEIGHT_M:-0.034}"
export XR_MONADO_IPD_M="${XR_MONADO_IPD_M:-0.064}"
export XR_MONADO_LENS_VERTICAL_POSITION_M="${XR_MONADO_LENS_VERTICAL_POSITION_M:-0.017}"
export XR_MONADO_FOV_LEFT="${XR_MONADO_FOV_LEFT:-1.0}"
export XR_MONADO_FOV_RIGHT="${XR_MONADO_FOV_RIGHT:-1.0}"
export XR_MONADO_FOV_UP="${XR_MONADO_FOV_UP:-1.0}"
export XR_MONADO_FOV_DOWN="${XR_MONADO_FOV_DOWN:-1.0}"
export XR_MONADO_REFRESH_HZ="${XR_MONADO_REFRESH_HZ:-${XR_DISPLAY_FREQUENCY_HZ:-90}}"

# -----------------------------------------------------------------------------
# SteamVR runtime apps
# -----------------------------------------------------------------------------
export STEAMVR_VIDEO_OVERLAY_DIR="${STEAMVR_VIDEO_OVERLAY_DIR:-$XR_BIN_ROOT/apps/steamvr/video_overlay}"
export STEAMVR_VIDEO_OVERLAY_BIN="${STEAMVR_VIDEO_OVERLAY_BIN:-$STEAMVR_VIDEO_OVERLAY_DIR/steamvr_video_overlay}"
export STEAMVR_VIDEO_OVERLAY_START_SCRIPT="${STEAMVR_VIDEO_OVERLAY_START_SCRIPT:-$STEAMVR_VIDEO_OVERLAY_DIR/scripts/linux/start_steamvr_video_overlay.sh}"

export XR_STEAMVR_SPATIAL_OVERLAY_DIR="${XR_STEAMVR_SPATIAL_OVERLAY_DIR:-$XR_BIN_ROOT/apps/steamvr/spatial_overlay}"
export XR_STEAMVR_SPATIAL_OVERLAY_BIN="${XR_STEAMVR_SPATIAL_OVERLAY_BIN:-$XR_STEAMVR_SPATIAL_OVERLAY_DIR/xr_steamvr_spatial_overlay}"
export XR_STEAMVR_SPATIAL_OVERLAY_START_SCRIPT="${XR_STEAMVR_SPATIAL_OVERLAY_START_SCRIPT:-$XR_STEAMVR_SPATIAL_OVERLAY_DIR/scripts/linux/start_xr_steamvr_spatial_overlay.sh}"
export SPATIAL_OVERLAY_CONFIG="${SPATIAL_OVERLAY_CONFIG:-$XR_STEAMVR_SPATIAL_OVERLAY_DIR/configs/profiles/runtime_shm.env}"

export XR_STEAMVR_SPATIAL_SCENE_DIR="${XR_STEAMVR_SPATIAL_SCENE_DIR:-$XR_BIN_ROOT/apps/steamvr/spatial_scene}"
export XR_STEAMVR_SPATIAL_SCENE_BIN="${XR_STEAMVR_SPATIAL_SCENE_BIN:-$XR_STEAMVR_SPATIAL_SCENE_DIR/xr_steamvr_spatial_scene}"
export XR_STEAMVR_SPATIAL_SCENE_START_SCRIPT="${XR_STEAMVR_SPATIAL_SCENE_START_SCRIPT:-$XR_STEAMVR_SPATIAL_SCENE_DIR/scripts/linux/start_xr_steamvr_spatial_scene.sh}"
export SPATIAL_SCENE_CONFIG="${SPATIAL_SCENE_CONFIG:-$XR_STEAMVR_SPATIAL_SCENE_DIR/configs/profiles/runtime_shm.env}"

# -----------------------------------------------------------------------------
# runtime_debug_viewer / tools
# -----------------------------------------------------------------------------
export XR_RUNTIME_DEBUG_VIEWER_CONFIG="${XR_RUNTIME_DEBUG_VIEWER_CONFIG:-$XR_DEVICE_CONFIGS_ROOT/runtime_debug_viewer/xr_runtime_stock.yaml}"
export STARTUP_GATE_SCRIPT="${STARTUP_GATE_SCRIPT:-$XR_CLIENT_DIR/tools/xr_startup_gate.py}"
