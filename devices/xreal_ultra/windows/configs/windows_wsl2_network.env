# XREAL Ultra Windows + WSL2 network profile.
# This file is consumed only by Windows-device scripts and WSL2 launch scripts.
# Values can still be overridden from the process environment.

# Windows package / WSL2 runtime placement.
XR_WSL2_DISTRO=Ubuntu-24.04
XR_WSL_PROJECT_ROOT=~/src/xr_tracking
XR_WSL_OUT_NAME=xreal_ultra

# Address of the Windows host as seen from WSL2.
# Use "auto" to resolve from /etc/resolv.conf inside WSL2.
XR_WINDOWS_HOST_FROM_WSL=auto

# Native Windows capture_service_cpp.
XR_CAPTURE_TCP_BIND_HOST=0.0.0.0
XR_CAPTURE_TCP_HOST_WINDOWS=127.0.0.1
XR_CAPTURE_TCP_PORT=45660
XR_CAPTURE_TCP_HOST_FROM_WSL=auto

# Native Windows override_controller TCP publisher.
XR_OVERRIDE_CONTROLLER_TCP_BIND_HOST=0.0.0.0
XR_OVERRIDE_CONTROLLER_TCP_HOST_WINDOWS=127.0.0.1
XR_OVERRIDE_CONTROLLER_TCP_PORT=45672
XR_OVERRIDE_CONTROLLER_TCP_HOST_FROM_WSL=auto

# Runtime UDP output target for the native Windows OpenVR driver.
XR_RUNTIME_OUTPUT_UDP_HOST_FROM_WSL=auto
XR_RUNTIME_POSE_UDP_PORT=45800
XR_RUNTIME_HAND_UDP_PORT=45801
XR_RUNTIME_CONTROLLER_STATE_UDP_PORT=45802

# Optional generic tracking UDP bridge target.
XR_TRACKING_UDP_TARGET_HOST_FROM_WSL=auto
XR_TRACKING_UDP_TARGET_PORT=45670
XR_SPATIAL_PROXY_MESH_UDP_PORT=45740

# WSL2 runtime service toggles.
RUN_WSL_BASALT_VIO=1
RUN_WSL_HAND_TRACKING=1
RUN_WSL_IMU_3DOF=0
RUN_WSL_XR_RUNTIME_ADAPTER=1
RUN_WSL_TRACKING_UDP_BRIDGE=0
RUN_WSL_XR_VIDEO=0
RUN_WSL_SPATIAL_MAPPER=0

# Shared WSL2 runtime registries.
XR_WSL_CAPTURE_REGISTRY=/tmp/capture_service_streams.json
XR_WSL_TRACKING_REGISTRY=/tmp/tracking_streams.json
XR_WSL_RUNTIME_TRACKING_REGISTRY=/tmp/runtime_tracking_streams.json
XR_WSL_RUNTIME_VIDEO_REGISTRY=/tmp/runtime_video_streams.json
