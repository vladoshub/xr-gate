# Runtime spatial proxy mesh -> SteamVR/OpenVR diagnostic overlay.
# This profile expects xr_runtime_adapter to publish runtime_spatial_proxy_mesh.

SPATIAL_OVERLAY_REGISTRY="${SPATIAL_OVERLAY_REGISTRY:-/tmp/runtime_tracking_streams.json}"
SPATIAL_OVERLAY_STREAM="${SPATIAL_OVERLAY_STREAM:-runtime_spatial_proxy_mesh}"
SPATIAL_OVERLAY_LOG_FILE="${SPATIAL_OVERLAY_LOG_FILE:-/tmp/xr_steamvr_spatial_overlay.log}"

# 0 = real SteamVR overlay. 1 = SHM/log-only diagnostic, no OpenVR init.
SPATIAL_OVERLAY_DRY_RUN="${SPATIAL_OVERLAY_DRY_RUN:-0}"

SPATIAL_OVERLAY_WIDTH="${SPATIAL_OVERLAY_WIDTH:-1280}"
SPATIAL_OVERLAY_HEIGHT="${SPATIAL_OVERLAY_HEIGHT:-720}"
SPATIAL_OVERLAY_RENDER_HZ="${SPATIAL_OVERLAY_RENDER_HZ:-60}"
# Stereo/SBS overlay mode.  This keeps the app as a SteamVR overlay but renders
# separate left/right eye projections into a side-by-side texture and sets the
# OpenVR SideBySide_Parallel overlay flag.
SPATIAL_OVERLAY_STEREO_SBS="${SPATIAL_OVERLAY_STEREO_SBS:-0}"
SPATIAL_OVERLAY_STEREO_IPD_M="${SPATIAL_OVERLAY_STEREO_IPD_M:-0.064}"
SPATIAL_OVERLAY_STEREO_OPENVR_FLAG="${SPATIAL_OVERLAY_STEREO_OPENVR_FLAG:-1}"
SPATIAL_OVERLAY_STEREO_DRAW_HUD="${SPATIAL_OVERLAY_STEREO_DRAW_HUD:-0}"
SPATIAL_OVERLAY_LOG_EVERY_SEC="${SPATIAL_OVERLAY_LOG_EVERY_SEC:-1.0}"
SPATIAL_OVERLAY_ATTACH_RETRY_MS="${SPATIAL_OVERLAY_ATTACH_RETRY_MS:-500}"

# Transparent HMD-relative diagnostic quad. The mesh is rendered into this texture
# from the current OpenVR HMD pose. This is an MVP/debug overlay, not a final
# driver-level 3D compositor mesh.
SPATIAL_OVERLAY_QUAD_WIDTH_M="${SPATIAL_OVERLAY_QUAD_WIDTH_M:-2.2}"
SPATIAL_OVERLAY_QUAD_DISTANCE_M="${SPATIAL_OVERLAY_QUAD_DISTANCE_M:-1.0}"
SPATIAL_OVERLAY_QUAD_Y_OFFSET_M="${SPATIAL_OVERLAY_QUAD_Y_OFFSET_M:-0.0}"
SPATIAL_OVERLAY_ALPHA="${SPATIAL_OVERLAY_ALPHA:-0.75}"
SPATIAL_OVERLAY_VERTICAL_FOV_DEG="${SPATIAL_OVERLAY_VERTICAL_FOV_DEG:-75}"
SPATIAL_OVERLAY_MIN_DEPTH_M="${SPATIAL_OVERLAY_MIN_DEPTH_M:-0.05}"
SPATIAL_OVERLAY_MAX_DEPTH_M="${SPATIAL_OVERLAY_MAX_DEPTH_M:-8.0}"
SPATIAL_OVERLAY_MAX_MESH_AGE_MS="${SPATIAL_OVERLAY_MAX_MESH_AGE_MS:-3000}"
# Static room/object maps remain useful even when the mapper is idle.
SPATIAL_OVERLAY_DRAW_STALE_MESH="${SPATIAL_OVERLAY_DRAW_STALE_MESH:-1}"
# Draw visible border/crosshair to prove that the SteamVR overlay itself is visible.
SPATIAL_OVERLAY_TEST_PATTERN="${SPATIAL_OVERLAY_TEST_PATTERN:-0}"
SPATIAL_OVERLAY_FORCE_VISIBLE_BORDER="${SPATIAL_OVERLAY_FORCE_VISIBLE_BORDER:-0}"

# Filled mesh is the default passthrough mode.  Wire/points are optional debug overlays.
SPATIAL_OVERLAY_DRAW_MESH="${SPATIAL_OVERLAY_DRAW_MESH:-1}"
SPATIAL_OVERLAY_DRAW_WIRE="${SPATIAL_OVERLAY_DRAW_WIRE:-0}"
SPATIAL_OVERLAY_DRAW_POINTS="${SPATIAL_OVERLAY_DRAW_POINTS:-0}"
SPATIAL_OVERLAY_DRAW_BBOX="${SPATIAL_OVERLAY_DRAW_BBOX:-0}"
SPATIAL_OVERLAY_POINT_RADIUS_PX="${SPATIAL_OVERLAY_POINT_RADIUS_PX:-2}"
SPATIAL_OVERLAY_MESH_ALPHA="${SPATIAL_OVERLAY_MESH_ALPHA:-0.38}"
SPATIAL_OVERLAY_WIRE_ALPHA="${SPATIAL_OVERLAY_WIRE_ALPHA:-0.82}"
SPATIAL_OVERLAY_POINT_ALPHA="${SPATIAL_OVERLAY_POINT_ALPHA:-0.85}"
SPATIAL_OVERLAY_VERBOSE_FRAMES="${SPATIAL_OVERLAY_VERBOSE_FRAMES:-0}"
SPATIAL_OVERLAY_KEY="${SPATIAL_OVERLAY_KEY:-xr_tracking.spatial_overlay}"
SPATIAL_OVERLAY_NAME="${SPATIAL_OVERLAY_NAME:-XR Spatial Overlay}"


# SteamVR/OpenVR environment for launching overlay apps outside Steam.
# This is needed on Linux when vrmonitor/vrserver cannot find libsteam_api.so.
SPATIAL_OVERLAY_AUTO_STEAMVR_ENV="${SPATIAL_OVERLAY_AUTO_STEAMVR_ENV:-1}"
SPATIAL_OVERLAY_STEAMVR_ROOT="${SPATIAL_OVERLAY_STEAMVR_ROOT:-}"
SPATIAL_OVERLAY_STEAM_ROOT="${SPATIAL_OVERLAY_STEAM_ROOT:-}"
SPATIAL_OVERLAY_DUMP_OPENVR_LDD="${SPATIAL_OVERLAY_DUMP_OPENVR_LDD:-1}"
# Set to 1 if you want the script to wait for SteamVR processes instead of letting OpenVR try to start them.
SPATIAL_OVERLAY_WAIT_STEAMVR="${SPATIAL_OVERLAY_WAIT_STEAMVR:-0}"
SPATIAL_OVERLAY_STEAMVR_WAIT_TIMEOUT_SEC="${SPATIAL_OVERLAY_STEAMVR_WAIT_TIMEOUT_SEC:-20}"


# Texture upload path.  Use opengl for continuous overlays; raw is only a smoke/debug fallback.
SPATIAL_OVERLAY_SUBMIT_MODE="${SPATIAL_OVERLAY_SUBMIT_MODE:-opengl}"


# Distance diagnostics rendered into the overlay HUD.
SPATIAL_OVERLAY_DRAW_DISTANCE_MARKERS="${SPATIAL_OVERLAY_DRAW_DISTANCE_MARKERS:-1}"
SPATIAL_OVERLAY_COLOR_BY_DISTANCE="${SPATIAL_OVERLAY_COLOR_BY_DISTANCE:-1}"
SPATIAL_OVERLAY_DISTANCE_MARKER_STEP_M="${SPATIAL_OVERLAY_DISTANCE_MARKER_STEP_M:-0.5}"
SPATIAL_OVERLAY_DISTANCE_MARKER_MAX_M="${SPATIAL_OVERLAY_DISTANCE_MARKER_MAX_M:-3.0}"


# Texture orientation fix for OpenVR/OpenGL overlay upload.  This is a 2D texture
# correction only.  3D mesh coordinate transforms stay in xr_runtime_adapter.
SPATIAL_OVERLAY_TEXTURE_FLIP_Y="${SPATIAL_OVERLAY_TEXTURE_FLIP_Y:-1}"
SPATIAL_OVERLAY_TEXTURE_FLIP_X="${SPATIAL_OVERLAY_TEXTURE_FLIP_X:-0}"
SPATIAL_OVERLAY_TEXTURE_ROTATE_180="${SPATIAL_OVERLAY_TEXTURE_ROTATE_180:-0}"


# Pose source for projection.  Use xr_runtime so runtime_spatial_proxy_mesh and
# runtime_hmd_pose are in the same runtime_local frame.  openvr is fallback only.
SPATIAL_OVERLAY_POSE_SOURCE="${SPATIAL_OVERLAY_POSE_SOURCE:-xr_runtime}"
SPATIAL_OVERLAY_POSE_REGISTRY="${SPATIAL_OVERLAY_POSE_REGISTRY:-/tmp/runtime_tracking_streams.json}"
SPATIAL_OVERLAY_POSE_STREAM="${SPATIAL_OVERLAY_POSE_STREAM:-runtime_hmd_pose}"
SPATIAL_OVERLAY_CLEAR_WHEN_NO_MESH="${SPATIAL_OVERLAY_CLEAR_WHEN_NO_MESH:-1}"
SPATIAL_OVERLAY_CLEAR_WHEN_NO_POSE="${SPATIAL_OVERLAY_CLEAR_WHEN_NO_POSE:-1}"
SPATIAL_OVERLAY_CLEAR_ON_STALE_SKIP="${SPATIAL_OVERLAY_CLEAR_ON_STALE_SKIP:-1}"
SPATIAL_OVERLAY_POSE_VERBOSE="${SPATIAL_OVERLAY_POSE_VERBOSE:-0}"
