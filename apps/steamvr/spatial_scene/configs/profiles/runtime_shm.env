# Runtime spatial proxy mesh -> OpenVR scene app.
# This is an experimental full scene application, not an overlay quad.

SPATIAL_SCENE_REGISTRY="${SPATIAL_SCENE_REGISTRY:-/tmp/runtime_tracking_streams.json}"
SPATIAL_SCENE_STREAM="${SPATIAL_SCENE_STREAM:-runtime_spatial_proxy_mesh}"
SPATIAL_SCENE_LOG_FILE="${SPATIAL_SCENE_LOG_FILE:-/tmp/xr_steamvr_spatial_scene.log}"

SPATIAL_SCENE_DRY_RUN="${SPATIAL_SCENE_DRY_RUN:-0}"
SPATIAL_SCENE_WIDTH="${SPATIAL_SCENE_WIDTH:-1280}"
SPATIAL_SCENE_HEIGHT="${SPATIAL_SCENE_HEIGHT:-1280}"
SPATIAL_SCENE_RENDER_HZ="${SPATIAL_SCENE_RENDER_HZ:-60}"
SPATIAL_SCENE_LOG_EVERY_SEC="${SPATIAL_SCENE_LOG_EVERY_SEC:-1.0}"
SPATIAL_SCENE_ATTACH_RETRY_MS="${SPATIAL_SCENE_ATTACH_RETRY_MS:-500}"
SPATIAL_SCENE_MAX_MESH_AGE_MS="${SPATIAL_SCENE_MAX_MESH_AGE_MS:-3000}"
SPATIAL_SCENE_DRAW_STALE_MESH="${SPATIAL_SCENE_DRAW_STALE_MESH:-1}"

SPATIAL_SCENE_DRAW_MESH="${SPATIAL_SCENE_DRAW_MESH:-1}"
SPATIAL_SCENE_DRAW_POINTS="${SPATIAL_SCENE_DRAW_POINTS:-0}"
SPATIAL_SCENE_DRAW_WIRE="${SPATIAL_SCENE_DRAW_WIRE:-0}"
SPATIAL_SCENE_POINT_SIZE="${SPATIAL_SCENE_POINT_SIZE:-3.0}"
SPATIAL_SCENE_ALPHA="${SPATIAL_SCENE_ALPHA:-0.70}"
SPATIAL_SCENE_COLOR_BY_DISTANCE="${SPATIAL_SCENE_COLOR_BY_DISTANCE:-1}"
SPATIAL_SCENE_NEAR_M="${SPATIAL_SCENE_NEAR_M:-0.05}"
SPATIAL_SCENE_FAR_M="${SPATIAL_SCENE_FAR_M:-8.0}"
SPATIAL_SCENE_VERBOSE_FRAMES="${SPATIAL_SCENE_VERBOSE_FRAMES:-0}"

# SteamVR/OpenVR environment for launching scene apps outside Steam.
SPATIAL_SCENE_AUTO_STEAMVR_ENV="${SPATIAL_SCENE_AUTO_STEAMVR_ENV:-1}"
SPATIAL_SCENE_STEAMVR_ROOT="${SPATIAL_SCENE_STEAMVR_ROOT:-}"
SPATIAL_SCENE_STEAM_ROOT="${SPATIAL_SCENE_STEAM_ROOT:-}"
SPATIAL_SCENE_WAIT_STEAMVR="${SPATIAL_SCENE_WAIT_STEAMVR:-0}"
SPATIAL_SCENE_STEAMVR_WAIT_TIMEOUT_SEC="${SPATIAL_SCENE_STEAMVR_WAIT_TIMEOUT_SEC:-20}"
SPATIAL_SCENE_DUMP_OPENVR_LDD="${SPATIAL_SCENE_DUMP_OPENVR_LDD:-1}"
